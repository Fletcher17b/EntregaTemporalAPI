# Auth API (login / refresh / logout — separate service)
AUTH_API_URL=http://localhost:8081

# Shared secret for Auth API -> AppBackend user provisioning (POST /api/internal/users)
AUTH_INTERNAL_API_KEY=change-me-in-production

# RSA public key PEM matching the Auth API JWT signing private key.
# Option A: inline PEM (use \n for line breaks in .env files that support it)
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjAN...\n-----END PUBLIC KEY-----
#
# Option B: mount/copy PEM file into the container and point to it
JWT_PUBLIC_KEY_LOCATION=classpath:jwt-public.pem

# Database (local dev)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/appbackend
SPRING_DATASOURCE_USERNAME=appbackend
SPRING_DATASOURCE_PASSWORD=appbackend
